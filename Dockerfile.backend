ARG PYTHON_IMAGE=python:3.12-slim
FROM ${PYTHON_IMAGE}
ARG INSTALL_CODEX_CLI=true
ARG CODEX_CLI_VERSION=0.130.0

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

RUN set -eux; \
    apt-get -o Acquire::Retries=5 update; \
    apt-get -o Acquire::Retries=5 install -y --no-install-recommends ca-certificates libgomp1; \
    rm -rf /var/lib/apt/lists/*

RUN set -eux; \
    if [ "$INSTALL_CODEX_CLI" = "true" ]; then \
        apt-get -o Acquire::Retries=5 update; \
        apt-get -o Acquire::Retries=5 install -y --no-install-recommends curl gnupg; \
        mkdir -p /etc/apt/keyrings; \
        curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg; \
        echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_24.x nodistro main" > /etc/apt/sources.list.d/nodesource.list; \
        apt-get -o Acquire::Retries=5 update; \
        apt-get -o Acquire::Retries=5 install -y --no-install-recommends nodejs; \
        npm install -g --include=optional "@openai/codex@${CODEX_CLI_VERSION}"; \
        codex_arch="$(node -p 'process.platform + "-" + process.arch')"; \
        case "$codex_arch" in \
            linux-x64|linux-arm64) codex_native="@openai/codex-${codex_arch}@npm:@openai/codex@${CODEX_CLI_VERSION}-${codex_arch}" ;; \
            *) echo "Unsupported Codex CLI Docker architecture: ${codex_arch}" >&2; exit 1 ;; \
        esac; \
        npm install --prefix "$(npm root -g)/@openai/codex" --include=optional "$codex_native"; \
        codex --version; \
        npm cache clean --force; \
        apt-get purge -y --auto-remove curl gnupg; \
        rm -rf /var/lib/apt/lists/*; \
    fi

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY alembic.ini .
COPY backend ./backend
COPY broker ./broker
COPY data ./data
COPY execution ./execution
COPY learning ./learning
COPY meta ./meta
COPY portfolio ./portfolio
COPY runtime ./runtime
COPY strategy ./strategy
COPY run_v2.py .

EXPOSE 8001

CMD ["gunicorn", "backend.app.main:app", "-k", "uvicorn.workers.UvicornWorker", "-b", "0.0.0.0:8001", "--workers", "2", "--timeout", "120"]
