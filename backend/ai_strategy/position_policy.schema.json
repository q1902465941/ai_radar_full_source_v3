{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "action": {
      "type": "string",
      "enum": ["HOLD", "PROTECT", "REDUCE", "EXIT"]
    },
    "thesis_alive": {
      "type": "boolean"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "noise_interpretation": {
      "type": "string",
      "enum": ["normal_noise", "warning_noise", "structure_weakening", "thesis_invalidated", "profit_protection"]
    },
    "invalidation": {
      "type": "string",
      "maxLength": 240
    },
    "reduce_ratio": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "stop_loss": {
      "type": "number",
      "minimum": 0
    },
    "learning_note": {
      "type": "string",
      "maxLength": 240
    },
    "safety_note": {
      "type": "string",
      "maxLength": 240
    }
  },
  "required": [
    "action",
    "thesis_alive",
    "confidence",
    "reason",
    "noise_interpretation",
    "invalidation",
    "reduce_ratio",
    "stop_loss",
    "learning_note",
    "safety_note"
  ]
}
